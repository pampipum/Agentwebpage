# Copy to: /etc/cloudflared/config.yml
# Replace <TUNNEL-UUID> and credentials-file path to match your tunnel

tunnel: <TUNNEL-UUID>
credentials-file: /etc/cloudflared/<TUNNEL-UUID>.json

ingress:
  - hostname: www.attikonlab.uk
    service: http://127.0.0.1:8090
  - hostname: attikonlab.uk
    service: http://127.0.0.1:8090
  - service: http_status:404
