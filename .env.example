# Optional: where to forward lead/report payloads (n8n/Make/Zapier webhook)
LEAD_WEBHOOK_URL=

# Optional: custom database location
# NAI_DB_PATH=/opt/attikonlab/data/nai_one.db

# TLS verification for outbound scan/webhook requests.
# Set true only if your VPS Python trust store is correctly configured.
NAI_TLS_VERIFY=false
